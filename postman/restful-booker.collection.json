{
  "info": {
    "_postman_id": "restful-booker-api-tests",
    "name": "Restful Booker API",
    "description": "Collection para testes manuais e exploratórios da API Restful Booker.\n\nFluxo sugerido:\n1. Auth - Create Token\n2. Booking - Create Booking (salva bookingId)\n3. Demais operações CRUD\n4. Pasta Negative Scenarios para validações",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://restful-booker.herokuapp.com" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "password123" },
    { "key": "token", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Create Token (success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token exists', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token).to.exist;",
                  "  pm.environment.set('token', json.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth"
          }
        },
        {
          "name": "Create Token (invalid password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (API design)', () => pm.response.to.have.status(200));",
                  "pm.test('Bad credentials', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.reason).to.eql('Bad credentials');",
                  "  pm.expect(json.token).to.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"wrong_password\"\n}"
            },
            "url": "{{baseUrl}}/auth"
          }
        }
      ]
    },
    {
      "name": "Booking",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Booking ID saved', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.bookingid).to.exist;",
                  "  pm.environment.set('bookingId', json.bookingid);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Joao\",\n  \"lastname\": \"Silva\",\n  \"totalprice\": 700,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-05-20\",\n    \"checkout\": \"2026-05-30\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": "{{baseUrl}}/booking"
          }
        },
        {
          "name": "Get All Bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/booking"
          }
        },
        {
          "name": "Get Booking by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/booking/{{bookingId}}"
          }
        },
        {
          "name": "Update Booking (PUT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Carlos\",\n  \"lastname\": \"QA\",\n  \"totalprice\": 999,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-07-01\",\n    \"checkout\": \"2026-07-10\"\n  },\n  \"additionalneeds\": \"Lunch\"\n}"
            },
            "url": "{{baseUrl}}/booking/{{bookingId}}"
          }
        },
        {
          "name": "Partial Update Booking (PATCH)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Patched\"\n}"
            },
            "url": "{{baseUrl}}/booking/{{bookingId}}"
          }
        },
        {
          "name": "Delete Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Cookie", "value": "token={{token}}" }],
            "url": "{{baseUrl}}/booking/{{bookingId}}"
          }
        }
      ]
    },
    {
      "name": "Negative Scenarios",
      "item": [
        {
          "name": "Create Booking - missing firstname",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Client error', () => pm.expect(pm.response.code).to.be.at.least(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lastname\": \"Silva\"\n}"
            },
            "url": "{{baseUrl}}/booking"
          }
        },
        {
          "name": "Create Booking - empty payload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Client error', () => pm.expect(pm.response.code).to.be.at.least(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/booking"
          }
        },
        {
          "name": "Get Booking - not found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/booking/999999999"
          }
        },
        {
          "name": "Update Booking - without token (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Hack\"\n}"
            },
            "url": "{{baseUrl}}/booking/{{bookingId}}"
          }
        },
        {
          "name": "Delete Booking - without auth (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/booking/{{bookingId}}"
          }
        },
        {
          "name": "Delete Booking - invalid token (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Cookie", "value": "token=token_fake" }],
            "url": "{{baseUrl}}/booking/{{bookingId}}"
          }
        },
        {
          "name": "Invalid HTTP method on booking (405)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Method not allowed', () => pm.expect(pm.response.code).to.be.oneOf([405, 404, 500]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "TRACE",
            "url": "{{baseUrl}}/booking"
          }
        }
      ]
    }
  ]
}
